   "source": [
    "def load(filename, encoding):\n",
    "    with open(filename, encoding=encoding) as f:\n",
    "        h = {}\n",
    "        for line in f :\n",
    "            timestamp,user,action,resource = line.split()\n",
    "            h.setdefault(user,[]).append((timestamp,action,resource))\n",
    "        return h"
   ]
  }
